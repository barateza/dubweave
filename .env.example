# ─────────────────────────────────────────────────────────────────────────────
# Dubweave Configuration Example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is safe to commit to git.

# ─────────────────────────────────────────────────────────────────────────────
# API Keys & Credentials
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter API Key (OPTIONAL)
# Get one at https://openrouter.ai/sign-up
# Leave empty "" to use local NLLB-200 translation instead.
# Free tier: $5 credits/month for development
# Production: Pay-as-you-go ($0.10/1M input, $0.40/1M output tokens)
# Cost estimate: ~$0.002 per 10-minute video
# Format: sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-your-key-here-or-leave-empty

# ─────────────────────────────────────────────────────────────────────────────
# Translation Models
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter — LLM-based context-aware translation
# Model: google/gemini-2.0-flash-001 (recommended for quality)
# Alternative models: openai/gpt-4-turbo, anthropic/claude-3-opus, etc.
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE=https://openrouter.ai/api/v1

# NLLB-200 — Local neural translation (no API key required)
# Run entirely on your GPU — best for privacy & cost-free use
# Model options:
#   facebook/nllb-200-distilled-600M  (recommended: 2.4GB, faster)
#   facebook/nllb-200-1.3B             (5.4GB, higher accuracy)
# Language codes (FLORES-200 standard):
#   English (source): eng_Latn
#   Portuguese (target): por_Latn
NLLB_MODEL=facebook/nllb-200-distilled-600M
NLLB_SRC_LANG=eng_Latn
NLLB_TGT_LANG=por_Latn

# ─────────────────────────────────────────────────────────────────────────────
# Speech Recognition (Transcription)
# ─────────────────────────────────────────────────────────────────────────────

# Whisper Model (OpenAI)
# Larger models = higher accuracy but slower + more VRAM
# Model options:
#   large-v3-turbo  (recommended: 4GB VRAM, ~2.5x faster than large-v3)
#   large-v3        (10GB VRAM, highest accuracy)
#   medium          (5GB VRAM, good balance)
#   small           (3GB VRAM, acceptable for noisy audio)
#   base, tiny      (<1GB VRAM, lower accuracy)
WHISPER_MODEL=large-v3-turbo

# ─────────────────────────────────────────────────────────────────────────────
# Text-to-Speech (TTS) — Kokoro
# ─────────────────────────────────────────────────────────────────────────────

# Language (Kokoro PT-BR)
# p = Portuguese (PT-BR)
KOKORO_LANG=p

# Voice preset
# pf_dora   (Female, energetic, recommended)
# pm_alex   (Male, natural)
# pm_santa  (Male, warm, friendly)
KOKORO_VOICE=pf_dora

# Speech rate multiplier
# 1.0 = natural speed (default)
# 1.2 = 20% faster (to fit tight synthesis time slots)
# 0.8 = 20% slower
KOKORO_SPEED=1.0

# ─────────────────────────────────────────────────────────────────────────────
# Gradio Web Interface
# ─────────────────────────────────────────────────────────────────────────────

# Server host/address
# 0.0.0.0 = accessible from any network interface (default)
# 127.0.0.1 = localhost only (no remote access)
# hostname.local = specific hostname
GRADIO_SERVER_NAME=0.0.0.0

# Server port
# Default: 7860
# Use 8000, 8080, etc. to avoid conflicts
GRADIO_SERVER_PORT=7860

# Share link (Gradio.live tunnel)
# false = local only (default, recommended for development)
# true = public gradio.live link (anyone with link can access)
GRADIO_SHARE=false
