# ─────────────────────────────────────────────────────────────────────────────
# Dubweave Configuration Example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# This file is safe to commit to git.

# ─────────────────────────────────────────────────────────────────────────────
# API Keys & Credentials
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter API Key (OPTIONAL)
# Get one at https://openrouter.ai/sign-up
# Leave empty "" to use local NLLB-200 translation instead.
# Free tier: $5 credits/month for development
# Production: Pay-as-you-go ($0.10/1M input, $0.40/1M output tokens)
# Cost estimate: ~$0.002 per 10-minute video
# Format: sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-your-key-here-or-leave-empty

# ─────────────────────────────────────────────────────────────────────────────
# Translation Models
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter — LLM-based context-aware translation
# Model: google/gemini-2.0-flash-001 (recommended for quality)
# Alternative models: openai/gpt-4-turbo, anthropic/claude-3-opus, etc.
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE=https://openrouter.ai/api/v1

# Tune how many utterances we send per OpenRouter call and how much history
# of translated text is prepended as read-only context.
# Keep chunk size well below the 1M-token window—start with 120-200 utterances.
OPENROUTER_CHUNK_SIZE=120
# Context size in utterances (0 = no context, 8 = eight previous translations)
OPENROUTER_CONTEXT_SIZE=8

# NLLB-200 — Local neural translation (no API key required)
# Run entirely on your GPU — best for privacy & cost-free use
# Model options:
#   facebook/nllb-200-distilled-600M  (recommended: 2.4GB, faster)
#   facebook/nllb-200-1.3B             (5.4GB, higher accuracy)
# Language codes (FLORES-200 standard):
#   English (source): eng_Latn
#   Portuguese (target): por_Latn
NLLB_MODEL=facebook/nllb-200-distilled-600M
NLLB_SRC_LANG=eng_Latn
NLLB_TGT_LANG=por_Latn

# ─────────────────────────────────────────────────────────────────────────────
# Speech Recognition (Transcription)
# ─────────────────────────────────────────────────────────────────────────────

# Whisper Model (OpenAI)
# Larger models = higher accuracy but slower + more VRAM
# Model options:
#   large-v3-turbo  (recommended: 4GB VRAM, ~2.5x faster than large-v3)
#   large-v3        (10GB VRAM, highest accuracy)
#   medium          (5GB VRAM, good balance)
#   small           (3GB VRAM, acceptable for noisy audio)
#   base, tiny      (<1GB VRAM, lower accuracy)
WHISPER_MODEL=large-v3-turbo

# ─────────────────────────────────────────────────────────────────────────────
# Text-to-Speech (TTS) — Kokoro
# ─────────────────────────────────────────────────────────────────────────────

# Language (Kokoro PT-BR)
# p = Portuguese (PT-BR)
KOKORO_LANG=p

# Voice preset
# pf_dora   (Female, energetic, recommended)
# pm_alex   (Male, natural)
# pm_santa  (Male, warm, friendly)
KOKORO_VOICE=pf_dora

# Speech rate multiplier
# 1.0 = natural speed (default)
# 1.2 = 20% faster (to fit tight synthesis time slots)
# 0.8 = 20% slower
KOKORO_SPEED=1.0

# Edge TTS — Microsoft neural voices (no API key required)
# PT-BR voice options:
#   pt-BR-FranciscaNeural  (Female, warm/conversational, recommended)
#   pt-BR-AntonioNeural    (Male, natural/neutral)
#   pt-BR-ThalitaNeural    (Female, energetic/younger cadence)
EDGE_TTS_VOICE_NAME=pt-BR-FranciscaNeural

# ─────────────────────────────────────────────────────────────────────────────
# Gradio Web Interface
# ─────────────────────────────────────────────────────────────────────────────
# Text-to-Speech (TTS) — Google Cloud TTS (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Google Cloud TTS API Key (OPTIONAL)
# Get one at https://console.cloud.google.com/apis/credentials
# Enable the "Cloud Text-to-Speech API" in your project first.
# Leave empty to disable Google Cloud TTS (uses Kokoro or XTTS instead).
# Format: AIzaSy... (API key from Google Cloud Console)
GOOGLE_TTS_API_KEY=

# Language code for synthesis
# Default: pt-BR (Brazilian Portuguese)
GOOGLE_TTS_LANGUAGE_CODE=pt-BR

# Voice type — selects which model family to use
# Options: Chirp3 HD | WaveNet | Standard | Studio | Neural2 | Polyglot (Preview)
#   Chirp3 HD          — Latest generation, highest quality
#                        Voices: Aoede, Charon, Fenrir, Kore, Leda, Orus, Puck, Schedar, Umbriel
#   Neural2            — High-quality neural voices (recommended for most use cases)
#   WaveNet            — High quality, slightly older than Neural2
#   Studio             — Extremely natural; higher latency and cost
#   Standard           — Fastest, lowest cost, lower quality
#   Polyglot (Preview) — Multilingual single-speaker; no dedicated PT-BR voices
GOOGLE_TTS_VOICE_TYPE=Neural2

# Voice name — must match the selected voice type and language code
# PT-BR voices by type:
#   Chirp3 HD:  pt-BR-Chirp3-HD-Achernar, pt-BR-Chirp3-HD-Achird, pt-BR-Chirp3-HD-Algenib, ...
#               (30 total voices available in the UI dropdown)
#   Neural2:    pt-BR-Neural2-A (F), pt-BR-Neural2-B (M), pt-BR-Neural2-C (F)
#   WaveNet:    pt-BR-Wavenet-A (F), pt-BR-Wavenet-B (M), pt-BR-Wavenet-C (F),
#               pt-BR-Wavenet-D (F), pt-BR-Wavenet-E (M)
#   Studio:     pt-BR-Studio-B (M), pt-BR-Studio-C (F)
#   Standard:   pt-BR-Standard-A (F), pt-BR-Standard-B (M), pt-BR-Standard-C (F),
#               pt-BR-Standard-D (F), pt-BR-Standard-E (M)
#   Polyglot:   No PT-BR-specific voices — set another language code or voice name manually
GOOGLE_TTS_VOICE_NAME=pt-BR-Neural2-A

# Gemini 3.1 Flash TTS Preview (OPTIONAL)
# Get API key at https://aistudio.google.com/apikey
# Model card: https://ai.google.dev/gemini-api/docs/models/gemini-3.1-flash-tts-preview
#
# Pricing (paid tier):
# Standard: input $1.00 / 1M text tokens, output $20.00 / 1M audio tokens
# Batch:    input $0.50 / 1M text tokens, output $10.00 / 1M audio tokens
# Audio token conversion: 25 tokens per second of generated audio
GEMINI_TTS_API_KEY=
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview

# Estimator mode:
# auto     = show one final cheapest estimate (recommended)
# standard = force standard pricing estimate
# batch    = force batch pricing estimate
GEMINI_TTS_PRICING_MODE=auto

# Single-speaker defaults
GEMINI_TTS_SINGLE_VOICE=Kore

# Multi-speaker defaults (up to 2 speakers)
GEMINI_TTS_MULTI_SPEAKER=false
# Assignment modes:
# alternate = alternate speakers per segment
# prefix    = parse "SpeakerName: text" prefix in each segment
GEMINI_TTS_SPEAKER_ASSIGNMENT=alternate
GEMINI_TTS_SPEAKER1_NAME=Speaker1
GEMINI_TTS_SPEAKER1_VOICE=Kore
GEMINI_TTS_SPEAKER2_NAME=Speaker2
GEMINI_TTS_SPEAKER2_VOICE=Puck

# ─────────────────────────────────────────────────────────────────────────────

# Server host/address
# 0.0.0.0 = accessible from any network interface (default)
# 127.0.0.1 = localhost only (no remote access)
# hostname.local = specific hostname
GRADIO_SERVER_NAME=0.0.0.0

# Server port
# Default: 7860
# Use 8000, 8080, etc. to avoid conflicts
GRADIO_SERVER_PORT=7860

# Share link (Gradio.live tunnel)
# false = local only (default, recommended for development)
# true = public gradio.live link (anyone with link can access)
GRADIO_SHARE=false
